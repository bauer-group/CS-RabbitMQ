# =============================================================================
# Git Ignore Configuration
# =============================================================================

# Environment (Secrets)
.env
.env.*
.env.bak
!.env.example

# Note: config/rabbitmq-init.json is the COMMITTED demo topology (dev bind-mount
# + production volume seed). It uses ${VAR} placeholders, not real secrets.
#
# NEVER commit real/production topologies (they carry credentials / password
# hashes). Any config/rabbitmq-init.<name>.json (migration, production, local, …)
# is ignored — deploy those onto the rabbitmq-config volume, not into git.
# Only the committed demo (above) and the .example reference are tracked.
config/rabbitmq-init.*.json
!config/rabbitmq-init.example.json

# Generated / mounted certificates
certs/
*.pem
*.key
*.crt

# IDE
.vscode/
.idea/
.claude/
*.code-workspace
.history/

# OS Files
.DS_Store
Thumbs.db
Desktop.ini
ehthumbs.db

# Logs
*.log
logs/

# Temporary Files
*.tmp
*.temp
*.bak
*~

# Python (rabbitmq-init container source)
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.venv/
venv/
